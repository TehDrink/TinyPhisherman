TINYFISH_API_KEY=
TINYFISH_API_URL=https://agent.tinyfish.ai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
URLSCAN_API_KEY=
URLSCAN_LOOKBACK_DAYS=7
URLSCAN_SCAN_TIMEOUT_MS=60000
DNSTWIST_PATH=dnstwist
# Hunt tuning — increase HUNT_MAX_CANDIDATES to widen the passive triage net;
# HUNT_MAX_VARIANTS caps how many pass through to TinyFish (cost/time tradeoff).
HUNT_MAX_CANDIDATES=20
HUNT_MAX_VARIANTS=8
